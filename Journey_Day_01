# 03. Python Basics: Input & Conditional Logic
# ==========================================

# --- Part A: Voting Eligibility (Integer Input) ---
age = int(input("Enter your age: "))

if age >= 18:
    print("You have the right to vote.")
else:
    print("Not eligible to vote yet.")

print("-" * 30) # Separator for clear output

# --- Part B: Student Grading System (Float Input) ---
marks = float(input("Enter your marks: "))

if marks >= 90:
    print("Grade: 'A'")
elif marks >= 80:
    print("Grade: 'B'")
elif marks >= 70:
    print("Grade: 'C'")
else:
    print("Performance: Poor")
