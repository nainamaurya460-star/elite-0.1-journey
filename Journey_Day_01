# 04. Cyber-Swarm System Battery Status Checker
# ==========================================

# Taking battery percentage input from the user
battery = float(input("Enter 'Divya' cell battery percentage (0-100): "))

# Checking system status based on battery levels
if battery <= 20:
    print("Warning: EPM connections might fail. Need Solar/Air-Gen charging")
elif battery >= 80:
    print("Cell fully charged. Ready for Swarm Mode")
else:
    print("Battery level is normal and in safe mode")

print("System status check complete.")
