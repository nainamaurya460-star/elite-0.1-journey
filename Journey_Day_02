# --- 3. Operators in Python ---

# A. Arithmetic Operator
a = 45
b = 56
c = a + b
print(c)

# B. Assignment Operator
a = 4 - 3
b = 5
b += 3  # Increments the value of b by 3 (b becomes 8)

# C. Comparison Operator (Always returns True or False)
d = 5 < 4
print(d)

# D. Logical Operators
e = True or False
print(e)

# Truth Table of 'or':
# True or True   -> True
# True or False  -> True
# False or True  -> True
# False or False -> False

# --- 4. Typecasting & Type Function ---
a = 23
b = float(a)  # Converts integer to float (23.0)
print(type(a))
print(type(b))

c = "creator"
print(type(c))

# --- 5. Input Function ---
# Note: input() always takes data as a String. 
# To add them as numbers, we use int() typecasting.
a = int(input("enter number 1: "))
b = int(input("enter number 2: "))

print("number a is: ", a)
print("number b is: ", b)
print("sum is:", a + b)  # Corrected: Now it will perform addition, not string joining
